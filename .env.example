# Storage mode: "local" (no AWS needed) or "s3" (default)
STORAGE_MODE=local

# Only needed if STORAGE_MODE=s3
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=neuroloop-data

# Claude Code hooks call this backend URL while an agent loop is running.
# The default matches setup.sh's local Uvicorn server.
NEUROLOOP_CLAUDE_HOOK_URL=http://127.0.0.1:8000/api/agent/hooks/claude

# Required for Llama-3.2-3B (gated model)
# Get yours at https://huggingface.co/settings/tokens
# Must first accept Meta's license at https://huggingface.co/meta-llama/Llama-3.2-3B
HF_TOKEN=your_huggingface_token_here
